#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/.venv/bin/python"
export PYTHONPATH="$SCRIPT_DIR/python-tools${PYTHONPATH:+:$PYTHONPATH}"

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "Portable Python tools are not installed yet."
  echo "Run ./install-python-tools.sh first."
  exit 1
fi

exec "$VENV_PYTHON" -m portable_ai_tools.cli "$@"
